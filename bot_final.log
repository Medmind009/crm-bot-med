import asyncio
import logging
import httpx
import gspread
import json
from google.oauth2 import service_account
from datetime import datetime

logging.basicConfig(level=logging.INFO)
logger = logging.getLogger(__name__)

TOKEN = '8712375566:AAGqUCjIf6MPy68Ayvrlx3LYZSdZxWLjgpE'
API_KEY = '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'
API_URL = f'https://api.telegram.org/bot{TOKEN}'
SPREADSHEET_ID = '1b7V6KHEPxcpthohDORDgK4X33OwcVxjcEdz_PSUOHbY'

# Google Sheets
creds_dict = json.load(open('google-credentials.json'))
creds = service_account.Credentials.from_service_account_info(creds_dict)
creds = creds.with_scopes(['https://spreadsheets.google.com/feeds', 'https://www.googleapis.com/auth/spreadsheets'])
sheet_client = gspread.authorize(creds)
sheet = sheet_client.open_by_key(SPREADSHEET_ID)

async def poll():
    offset = 0
    async with httpx.AsyncClient(timeout=30) as client:
        while True:
            try:
                r = await client.get(f'{API_URL}/getUpdates', params={'timeout': 25, 'offset': offset})
                data = r.json()
                
                for update in data.get('result', []):
                    offset = update['update_id'] + 1
                    msg = update.get('message', {})
                    if msg:
                        chat = msg.get('chat', {})
                        text = msg.get('text', '')
                        first_name = msg.get('from', {}).get('first_name', '')
                        
                        logger.info(f'Received: {text[:50]}')
                        
                        if text == '/start':
                            await send(client, chat['id'], f'👋 Привет! Я CRM-бот. Отправь отчет о встрече.')
                        elif text == '/help':
                            await send(client, chat['id'], '📖 /help — справка\n📝 Отправь отчет о клинике')
                        elif text.startswith('/'):
                            await send(client, chat['id'], '❓ Неизвестная команда')
                        else:
                            await process_report(client, chat, msg.get('from', {}), text)
                            
            except Exception as e:
                logger.error(f'Error: {e}')
                await asyncio.sleep(5)

async def send(client, chat_id, text):
    await client.post(f'{API_URL}/sendMessage', json={'chat_id': chat_id, 'text': text, 'parse_mode': 'HTML'})

async def process_report(client, chat, from_user, text):
    first_name = from_user.get('first_name', '')
    
    # AI parsing
    payload = {
        'model': 'google/gemini-2.0-flash-001',
        'messages': [
            {'role': 'system', 'content': 'Извлеки данные из отчета о клинике. Верни JSON.'},
            {'role': 'user', 'content': f'Отчет: {text}'}
        ],
        'temperature': 0.2,
        'response_format': {'type': 'json_object'}
    }
    
    r = await client.post('https://openrouter.ai/api/v1/chat/completions', json=payload, headers={
        'Authorization': f'Bearer {API_KEY}',
        'Content-Type': 'application/json'
    })
    data = r.json()
    parsed = json.loads(data['choices'][0]['message']['content'])
    
    # Write to Google Sheets - Лиды
    ws = sheet.worksheet('Лиды')
    ws.append_row([
        datetime.now().strftime('%d.%m.%Y'),
        parsed.get('клиника', ''),
        parsed.get('contact_name', ''),
        parsed.get('должность', ''),
        parsed.get('decision_maker', ''),
        parsed.get('телефон', ''),
        parsed.get('interaction_format', 'Telegram'),
        parsed.get('sent_materials', ''),
        parsed.get('реакция', ''),
        parsed.get('next_step', ''),
        parsed.get('next_step_date', ''),
        parsed.get('lead_status', 'Новый'),
        parsed.get('ответственный', first_name),
        parsed.get('comment', '')
    ])
    
    # Also to Касания
    try:
        ws2 = sheet.worksheet('Касания')
        ws2.append_row([
            datetime.now().strftime('%d.%m.%Y'),
            parsed.get('ответственный', first_name),
            'Telegram',
            parsed.get('реакция', ''),
            parsed.get('sent_materials', ''),
            parsed.get('client_questions', ''),
            parsed.get('ответы_даны', ''),
            parsed.get('interaction_result', ''),
            parsed.get('next_step', ''),
            parsed.get('comment', ''),
            parsed.get('клиника', '')
        ])
    except:
        pass
    
    # Also to Задачи
    if parsed.get('task_needed'):
        try:
            ws3 = sheet.worksheet('Задачи')
            ws3.append_row([
                parsed.get('клиника', ''),
                parsed.get('task_title', ''),
                datetime.now().strftime('%d.%m.%Y %H:%M'),
                parsed.get('next_step_date', ''),
                parsed.get('ответственный', first_name),
                'Новая',
                parsed.get('task_priority', 'Средний')
            ])
        except:
            pass
    
    status = {'Интерес': '🤔', 'Переговоры': '💬', 'Сделка': '✅'}.get(parsed.get('lead_status', 'Интерес'), '📋')
    
    response = f\"\"\"✅ <b>Сохранено!</b>

🏥 Клиника: {parsed.get('клиника', '-')}
👤 Контакт: {parsed.get('contact_name', '-')}
📊 Статус: {status} {parsed.get('lead_status', 'Интерес')}

📌 Шаг: {parsed.get('next_step', '-')}
📅 Дедлайн: {parsed.get('next_step_date', '-')}

📝 Записано в CRM!\"\"\"
    
    await send(client, chat['id'], response)

logger.info('🚀 CRM Бот запущен с Google Sheets!')
asyncio.run(poll())
